{
    "name": "waad/laravel-model-metadata",
    "description": "A robust Laravel package for handling metadata with JSON casting, custom relation names, and advanced querying capabilities.",
    "type": "library",
    "keywords": [
        "laravel",
        "metadata",
        "model",
        "json",
        "eloquent",
        "database",
        "flexible",
        "schema-less"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Waad Mawlood",
            "email": "waad_mawlood@outlook.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-json": "*",
        "laravel/framework": "^9.30.1|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest-plugin-laravel": "^1.4|^2.4|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Waad\\Metadata\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waad\\Metadata\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Waad\\Metadata\\Providers\\MetadataServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "php -c php-test.ini vendor/bin/pest",
        "test:coverage": "php -c php-test.ini vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    }
}
